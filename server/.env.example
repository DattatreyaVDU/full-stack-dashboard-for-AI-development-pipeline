# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=*

# ── Storage ───────────────────────────────────────────────────────────────────
# NAS path (Synology): /volume1/Workflows/Website-Generator/projects
# Local dev fallback:  leave empty (uses <repo-root>/projects/)
PROJECTS_DIR=/volume1/Workflows/Website-Generator/projects

# Path to db.json — use a persistent volume on NAS
# Local dev fallback: leave empty (uses <repo-root>/db.json)
DB_PATH=/volume1/Workflows/Website-Generator/data/db.json

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret between n8n HTTP Request nodes and this backend
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=change_this_to_a_random_secret

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_CHAT_URL=https://your-n8n-domain.com/webhook/YOUR_WEBHOOK_ID/chat

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repository_name
GITHUB_BRANCH=main

# ── FTP (EasyWP) ──────────────────────────────────────────────────────────────
FTP_HOST=ftp.your-easywp-domain.com
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_REMOTE_PATH=/wp-content/themes
