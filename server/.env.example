# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repository_name
GITHUB_BRANCH=main

# EasyWP FTP Credentials
FTP_HOST=ftp.your-easywp-domain.com
FTP_USER=your_ftp_username
FTP_PASS=your_ftp_password
FTP_REMOTE_PATH=/wp-content/themes

# n8n
N8N_WEBHOOK_SECRET=your_shared_secret_key
# Chat webhook URL — find the webhookId in your n8n chatTrigger node
# Format: https://YOUR_N8N_DOMAIN/webhook/WEBHOOK_ID/chat
N8N_CHAT_URL=https://your-n8n-domain.com/webhook/6d8e1ecf-ed7a-42ba-82d7-160a3ee4b5e9/chat
